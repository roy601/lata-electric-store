# ─── Server ───────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# ─── Supabase ─────────────────────────────────────────────
SUPABASE_URL=https://xxxxxx.supabase.co
SUPABASE_ANON_KEY=your_anon_public_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ─── JWT ──────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=REPLACE_WITH_64_BYTE_HEX_SECRET
JWT_REFRESH_SECRET=REPLACE_WITH_DIFFERENT_64_BYTE_HEX_SECRET

JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# ─── Cookie ───────────────────────────────────────────────
COOKIE_SECRET=REPLACE_WITH_32_BYTE_HEX_SECRET

# ─── CORS ─────────────────────────────────────────────────
CLIENT_URL=http://localhost:5173

# ─── Rate Limiting ────────────────────────────────────────
LOGIN_MAX_ATTEMPTS=5
LOGIN_WINDOW_MINUTES=15
ACCOUNT_LOCKOUT_MINUTES=30

# ─── First-time Admin Seed (run: npm run seed) ────────────
# Remove these after seeding — they are only needed once.
SEED_ADMIN_EMAIL=your@email.com
SEED_ADMIN_PASSWORD=ChangeMe@123
SEED_ADMIN_NAME=Your Name
